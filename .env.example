# Copy to .env and fill in your values.
# The CLI auto-loads .env on startup.

# ── OpenRouter (default) ─────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Or use Ollama locally (no key needed) ─────────────
# See README.md#configuration for switching providers.

# ── Or use direct provider keys ──────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
